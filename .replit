modules = ["nodejs-22"]
[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Dev"

[[workflows.workflow]]
name = "Frontend Dev"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && pnpm dev"
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 80
